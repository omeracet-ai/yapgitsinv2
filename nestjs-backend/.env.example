# nestjs-backend — local/dev environment template
# Copy to .env and fill real values. NEVER commit .env.
# For production keys see .env.production.example + docs/SECRETS_ROTATION.md

# --- Core ---
PORT=3001
NODE_ENV=development

# --- Database ---
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=change_me_db_user
DB_PASSWORD=change_me_db_password
DB_NAME=hizmet_db
# DB_SYNCHRONIZE=false   # prod-only flag, keep false in prod

# --- Auth ---
# Generate: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret
# Optional dual-secret rotation window (NOT YET IMPLEMENTED — see SECRETS_ROTATION.md TODO)
# JWT_SECRET_PREVIOUS=
ADMIN_INITIAL_PASSWORD=change_me_admin_password

# --- Payments (iyzico) ---
IYZIPAY_API_KEY=change_me_iyzipay_api_key
IYZIPAY_SECRET_KEY=change_me_iyzipay_secret_key
IYZIPAY_URI=https://sandbox-api.iyzipay.com

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=change_me_anthropic_api_key

# --- CORS / fees ---
ALLOWED_ORIGINS=http://localhost:3000
PLATFORM_FEE_PCT=10

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Firebase Cloud Messaging (optional) ---
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# --- Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Yapgitsin <noreply@yapgitsin.tr>"

# --- SMS OTP (optional) ---
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=YAPGITSIN
NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
