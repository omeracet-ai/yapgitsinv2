# nestjs-backend — local/dev environment template
# Copy to .env and fill real values. NEVER commit .env.
# For production keys see .env.production.example + docs/SECRETS_ROTATION.md

# --- Core ---
PORT=3001
NODE_ENV=development

# --- Database ---
# ŞU AN: proje SQLite ile çalışıyor (dev + prod). DB_TYPE=sqlite => app.module.ts
# synchronize: true (entity'den otomatik şema). DB_NAME = sqlite dosya adı.
DB_TYPE=sqlite
DB_NAME=hizmet_db.sqlite
# RDBMS'e (MySQL/Postgres) geçilirse: DB_TYPE'ı değiştir + aşağıdakileri doldur.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=change_me_db_user
# DB_PASSWORD=change_me_db_password
# DB_SYNCHRONIZE=false   # yalnızca mysql branch'inde + non-prod'da okunur; RDBMS prod'da migration kullan

# --- Auth ---
# Generate: openssl rand -base64 48
JWT_SECRET=change_me_jwt_secret
# Optional: previous signing key, kept during a zero-downtime JWT_SECRET rotation
# window so tokens issued before the rotation still verify. Leave empty when not
# rotating. See docs/SECRETS_ROTATION.md §4.
JWT_SECRET_PREVIOUS=
ADMIN_INITIAL_PASSWORD=change_me_admin_password

# --- Payments (iyzico) ---
IYZIPAY_API_KEY=change_me_iyzipay_api_key
IYZIPAY_SECRET_KEY=change_me_iyzipay_secret_key
IYZIPAY_URI=https://sandbox-api.iyzipay.com
# Public base URL — used to build the iyzipay callback (<base>/backend/payments/iyzipay/callback)
# APP_BASE_URL=https://yapgitsin.tr
# Set MOCK_IYZIPAY=1 to bypass live iyzipay calls (returns fake checkout/refund responses)
# MOCK_IYZIPAY=0

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=change_me_anthropic_api_key

# --- CORS / fees ---
ALLOWED_ORIGINS=http://localhost:3000
PLATFORM_FEE_PCT=10

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Firebase Cloud Messaging (optional) ---
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# --- Email SMTP (optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Yapgitsin <noreply@yapgitsin.tr>"

# --- SMS OTP (optional) ---
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=YAPGITSIN
NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Cache (Phase 170) ────────────────────────────────────────────
# REDIS_URL boşsa in-memory cache kullanılır (dev varsayılanı). Prod için bkz docs/REDIS_SETUP.md
# REDIS_URL=redis://localhost:6379

# ── Admin seed (Phase 181) ───────────────────────────────────────
# Set to 1 ONLY when running /admin/seed/* endpoints (wipe/populate prod DB).
# Default OFF. Turn back to empty/unset and restart after seeding.
# ALLOW_SEED=
