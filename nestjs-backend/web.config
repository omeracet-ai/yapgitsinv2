<?xml version="1.0" encoding="utf-8"?>
<!--
  Yapgitsin NestJS backend — IIS + iisnode bridge (Phase 166)
  Deployed to: D:\backend on Plesk Windows host (yapgitsin.tr)
  Entry point: dist/main.js (NestJS bootstrap)
  Requires: iisnode module installed (%programfiles%\iisnode\iisnode.dll)
-->
<configuration>
  <system.webServer>

    <!-- iisnode handler: route Node.js requests to dist/main.js -->
    <handlers>
      <add name="iisnode" path="dist/main.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- URL Rewrite: forward all incoming requests to the Node entry -->
    <rewrite>
      <rules>
        <!-- Skip rewrite for iisnode debugger UI -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^dist/main.js\/debug[\/]?" />
        </rule>

        <!-- Pass-through static files inside /uploads (served by Node, but allow IIS direct hit) -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^uploads/.*" />
          <action type="None" />
        </rule>

        <!-- All other requests -> dist/main.js -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="dist/main.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode runtime configuration -->
    <iisnode
      nodeProcessCommandLine="node.exe"
      watchedFiles="*.js;dist\*.js;dist\**\*.js;web.config"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      devErrorsEnabled="false"
      maxLogFileSizeInKB="1024"
      maxTotalLogFileSizeInKB="10240"
      maxLogFiles="20"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      asyncCompletionThreadCount="0"
      initialRequestBufferSize="4096"
      maxRequestBufferSize="65536"
      uncFileChangesPollingInterval="5000"
      gracefulShutdownTimeout="60000"
    />

    <!-- Security: hide Node-related files from direct download -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".env.production" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sqlite" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Allow large uploads (50MB job videos) -->
    <httpErrors errorMode="Detailed" />

  </system.webServer>
</configuration>
