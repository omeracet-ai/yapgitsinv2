<?xml version="1.0" encoding="utf-8"?>
<!--
  Yapgitsin NestJS backend — IIS + iisnode bridge (Phase 166/168)
  Deployed to: D:\backend on Plesk Windows host (yapgitsin.tr)
  Entry point: src/main.js (deploy-to-d.sh flattens dist/* so dist/src/main.js -> D:\backend\src\main.js)
  Requires: iisnode module installed (%programfiles%\iisnode\iisnode.dll)
-->
<configuration>
  <system.webServer>

    <!-- iisnode aktif. Plesk -> Node.js: Application Root=httpdocs/backend, Startup File=src/main.js, NODE_ENV=production. iisnode modülü Plesk Node.js extension'ı kuruluysa devrede. -->
    <handlers>
      <!-- Remove IIS built-in OPTIONS handler so NestJS CORS middleware handles it -->
      <remove name="OPTIONSVerbHandler" />
      <add name="iisnode" path="src/main.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- iisnode bind edilmezse statik placeholder fallback için default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- URL Rewrite: forward all incoming requests to the Node entry -->
    <rewrite>
      <rules>
        <!-- Skip rewrite for iisnode debugger UI -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^src/main.js\/debug[\/]?" />
        </rule>

        <!-- Pass-through only EXISTING static files inside /uploads (API endpoints like /uploads/job-photos go to NestJS) -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^uploads/.*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- All other requests -> src/main.js -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="src/main.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode runtime config Plesk Node.js extension tarafından yönetiliyor (node binary yolu, logging vs). Buraya iisnode runtime elementi EKLEME — nodeProcessCommandLine override'ı 500.1000'e yol açar. -->

    <!-- Security: hide Node-related files from direct download -->
    <security>
      <requestFiltering>
        <!-- <clear /> drops segments inherited from the parent (/httpdocs/web.config),
             preventing "duplicate collection entry ... node_modules" 500.19 errors. -->
        <hiddenSegments>
          <clear />
          <add segment="web.config" />
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".env.production" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sqlite" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Allow large uploads (50MB job videos) -->
    <httpErrors errorMode="Detailed" />

  </system.webServer>
</configuration>
