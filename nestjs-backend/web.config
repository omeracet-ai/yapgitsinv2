<?xml version="1.0" encoding="utf-8"?>
<!--
  Yapgitsin NestJS backend — IIS + iisnode bridge (Phase 166/168)
  Deployed to: D:\backend on Plesk Windows host (yapgitsin.tr)
  Entry point: src/main.js (deploy-to-d.sh flattens dist/* so dist/src/main.js -> D:\backend\src\main.js)
  Requires: iisnode module installed (%programfiles%\iisnode\iisnode.dll)
-->
<configuration>
  <system.webServer>

    <!-- Plesk Node.js düzgün yapılandırılınca bu bloğu + aşağıdaki DynamicContent rewrite'ını geri aç. Şu an iisnode yok -> statik placeholder serve ediliyor. -->
    <!--
    <handlers>
      <add name="iisnode" path="src/main.js" verb="*" modules="iisnode" />
    </handlers>
    -->

    <!-- Statik placeholder için default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- URL Rewrite: forward all incoming requests to the Node entry -->
    <rewrite>
      <rules>
        <!-- Skip rewrite for iisnode debugger UI -->
        <!--
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^src/main.js\/debug[\/]?" />
        </rule>
        -->

        <!-- Pass-through static files inside /uploads (served by Node, but allow IIS direct hit) -->
        <!--
        <rule name="StaticContent" stopProcessing="true">
          <match url="^uploads/.*" />
          <action type="None" />
        </rule>
        -->

        <!-- All other requests -> src/main.js (iisnode yok -> devre dışı) -->
        <!--
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="src/main.js" />
        </rule>
        -->
      </rules>
    </rewrite>

    <!-- iisnode runtime configuration (iisnode yok -> devre dışı) -->
    <!--
    <iisnode
      nodeProcessCommandLine="node.exe"
      watchedFiles="*.js;src\*.js;src\**\*.js;web.config"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      devErrorsEnabled="false"
      maxLogFileSizeInKB="1024"
      maxTotalLogFileSizeInKB="10240"
      maxLogFiles="20"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      asyncCompletionThreadCount="0"
      initialRequestBufferSize="4096"
      maxRequestBufferSize="65536"
      uncFileChangesPollingInterval="5000"
      gracefulShutdownTimeout="60000"
    />
    -->

    <!-- Security: hide Node-related files from direct download -->
    <security>
      <requestFiltering>
        <!-- <clear /> drops segments inherited from the parent (/httpdocs/web.config),
             preventing "duplicate collection entry ... node_modules" 500.19 errors. -->
        <hiddenSegments>
          <clear />
          <add segment="web.config" />
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".env.production" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sqlite" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <!-- Allow large uploads (50MB job videos) -->
    <httpErrors errorMode="Detailed" />

  </system.webServer>
</configuration>
