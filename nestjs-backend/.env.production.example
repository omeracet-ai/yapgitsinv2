# NOT: iisnode/Plesk Node altında process.cwd() != uygulama dizini; bu yüzden ConfigModule
# envFilePath APP_ROOT'a (= bu dosyanın bulunduğu klasör) göre çözülür. Alternatif: env'leri
# Plesk Node.js panelindeki "Environment Variables" bölümüne de girebilirsin (oradakiler
# dosyadan bağımsız, doğrudan process.env'e yüklenir).
#
# NOT: Canlı server şu an NODE_ENV'i SET ETMİYOR -> ConfigModule .env dosyasına düşer,
# bu .env.production yüklenmez. NODE_ENV=production set edilirse bu dosya aktif olur ve
# isProd=true => synchronize KAPANIR, migrationsRun açılır. SQLite + boş şema ile bu çakışır;
# o yüzden RDBMS'e geçmeden NODE_ENV=production AÇMA.
# NODE_ENV=production
PORT=3001
# GLOBAL_PREFIX=  (boş bırak — api.yapgitsin.tr subdomain'inde prefix gerekmez; sadece yapgitsin.tr/backend/ yolu kullanılırsa "backend" set et)
# ŞU AN: production SQLite ile çalışıyor (hizmet_db.sqlite). RDBMS'e geçilirse aşağıdaki
# postgres/mysql satırlarını aç + DB_TYPE'ı değiştir.
DB_TYPE=sqlite
DB_NAME=hizmet_db.sqlite
# DB_TYPE=postgres
# DB_HOST=
# DB_PORT=5432
# DB_USERNAME=
# DB_PASSWORD=
# DB_NAME=yapgitsin_prod
JWT_SECRET=
# Set only during a zero-downtime JWT rotation window (= the old JWT_SECRET value);
# remove once all old tokens have expired. See docs/SECRETS_ROTATION.md §4.
JWT_SECRET_PREVIOUS=
ADMIN_INITIAL_PASSWORD=
ANTHROPIC_API_KEY=
ALLOWED_ORIGINS=https://yapgitsin.tr,https://www.yapgitsin.tr
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=
IYZIPAY_URI=https://api.iyzipay.com
# APP_BASE_URL=https://yapgitsin.tr
# MOCK_IYZIPAY=0

# Sentry (optional — error tracking, prod-only)
SENTRY_DSN=

# Phase 113 — Firebase Cloud Messaging (optional)
# Service account JSON — paste raw JSON or base64-encoded JSON.
# Without this, push notifications are silently disabled.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# Phase 121 — Transactional Email (Nodemailer SMTP, optional)
# Without SMTP_HOST, email is silently disabled.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Yapgitsin <noreply@yapgitsin.tr>"

# Phase 123 — SMS OTP (Netgsm primary, Twilio fallback)
NETGSM_USER=
NETGSM_PASS=
NETGSM_HEADER=YAPGITSIN
NETGSM_API_URL=https://api.netgsm.com.tr/sms/send/get
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Cache (Phase 170) ────────────────────────────────────────────
# REDIS_URL boşsa in-memory cache kullanılır. Windows sunucuda Memurai önerilir — bkz docs/REDIS_SETUP.md
# REDIS_URL=redis://localhost:6379
