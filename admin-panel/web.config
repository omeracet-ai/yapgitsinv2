<?xml version="1.0" encoding="utf-8"?>
<!--
  Yapgitsin Admin Panel — Next.js standalone on IIS + iisnode (Phase 166)
  Deployed to: D:\admin on Plesk Windows host (yapgitsin.tr/admin)
  Entry point: server.js (Next.js standalone server)
  Requires: iisnode module installed (%programfiles%\iisnode\iisnode.dll)
-->
<configuration>
  <system.webServer>

    <!-- iisnode aktif. Plesk -> Node.js: Application Root=httpdocs/admin, Startup File=server.js, NODE_ENV=production. iisnode modülü Plesk Node.js extension'ı kuruluysa devrede. -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <!-- iisnode bind edilmezse statik placeholder fallback için default document -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- URL Rewrite: forward all incoming requests to the Next.js standalone entry -->
    <rewrite>
      <rules>
        <!-- Skip rewrite for iisnode debugger UI -->
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^server.js\/debug[\/]?" />
        </rule>

        <!-- Pass-through Next.js static assets directly via IIS for performance -->
        <rule name="NextStatic" stopProcessing="true">
          <match url="^_next/static/.*" />
          <action type="None" />
        </rule>

        <!-- Pass-through public/ assets -->
        <rule name="PublicAssets" stopProcessing="true">
          <match url="^(favicon\.ico|robots\.txt|sitemap\.xml|.*\.(png|jpg|jpeg|svg|webp|woff2?|css|js|map))$" />
          <action type="None" />
        </rule>

        <!-- All other requests -> server.js -->
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode runtime configuration -->
    <iisnode
      nodeProcessCommandLine="node.exe"
      watchedFiles="server.js;web.config;.next\BUILD_ID"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      devErrorsEnabled="false"
      maxLogFileSizeInKB="1024"
      maxTotalLogFileSizeInKB="10240"
      maxLogFiles="20"
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
      asyncCompletionThreadCount="0"
      initialRequestBufferSize="4096"
      maxRequestBufferSize="65536"
      uncFileChangesPollingInterval="5000"
      gracefulShutdownTimeout="60000"
    />

    <!-- Security: hide sensitive files -->
    <security>
      <requestFiltering>
        <!-- <clear /> drops segments inherited from the parent (/httpdocs/web.config),
             preventing "duplicate collection entry ... node_modules" 500.19 errors. -->
        <hiddenSegments>
          <clear />
          <add segment="web.config" />
          <add segment="node_modules" />
          <add segment="iisnode" />
          <add segment=".env" />
          <add segment=".env.production" />
          <add segment=".next" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <httpErrors errorMode="Detailed" />

  </system.webServer>
</configuration>
