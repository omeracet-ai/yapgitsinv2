<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system SplashScreen attributes (no androidx dep needed).
         Background matches AppColors.background (#0C1117) and the icon is a
         1dp transparent shape so the default Flutter logo never renders.
         Hand-off goes straight to the Flutter SplashScreen widget. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#FF0C1117</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
