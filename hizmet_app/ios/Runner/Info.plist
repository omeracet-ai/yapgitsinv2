		     REPLACE the placeholder below with REVERSED_CLIENT_ID from
		     ios/Runner/GoogleService-Info.plist (download from Firebase
		     Console > Project settings > add iOS app).
		     Format: com.googleusercontent.apps.<NNNNNNNNNNNN>-<hash> -->
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>google-sign-in</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.264858879848-b2ji4soue7n0rnpnq62ugnjuh4b6uu02</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
