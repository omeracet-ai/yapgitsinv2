rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile photos
    match /users/{userId}/avatar/{file} {
      allow read: if true;
      allow write: if request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Job photos
    match /jobs/{jobId}/photos/{file} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Chat attachments
    match /chats/{chatId}/attachments/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    // Provider portfolio
    match /providers/{providerId}/portfolio/{file} {
      allow read: if true;
      allow write: if request.auth.uid == providerId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Admin uploads (onboarding slides, category icons)
    match /admin/{path=**} {
      allow read: if true;
      allow write: if request.auth.token.role == 'admin';
    }
  }
}
